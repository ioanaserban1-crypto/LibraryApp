<Window x:Class="NivelUIWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library App" Height="700" Width="1000"
        MinWidth="700" MinHeight="500">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="DarkBlue"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5,5,5,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- MENIU -->
        <Menu Grid.Row="0">
            <MenuItem Header="Cărți">
                <MenuItem Header="Adaugă carte" Click="MenuAdauga_Click"/>
                <MenuItem Header="Modifică carte" Click="MenuModifica_Click"/>
                <Separator/>
                <MenuItem Header="Șterge carte"/>
            </MenuItem>
            <MenuItem Header="Autori">
                <MenuItem Header="Gestionare autori" Click="MenuAutori_Click"/>
            </MenuItem>
            <MenuItem Header="Persoane">
                <MenuItem Header="Gestionare persoane" Click="MenuPersoane_Click"/>
            </MenuItem>
            <MenuItem Header="Împrumuturi">
                <MenuItem Header="Împrumută carte" Click="MenuImprumuta_Click"/>
                <MenuItem Header="Returnează carte" Click="MenuReturneaza_Click"/>
                <Separator/>
                <MenuItem Header="Vezi împrumuturi active" Click="MenuVeziImprumuturi_Click"/>
            </MenuItem>
            <MenuItem Header="File">
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </MenuItem>
        </Menu>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== COLOANA STANGA ===== -->
                <StackPanel Grid.Column="0" Margin="5">

                    <TextBlock Text="Detalii carte"
                               FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Label Content="Titlu:"/>
                    <TextBlock Text="{Binding CarteCurenta.Titlu, Mode=OneWay}" Margin="5"/>
                    <Label Content="Autor:"/>
                    <TextBlock Text="{Binding CarteCurenta.Autor.Nume, Mode=OneWay}" Margin="5"/>
                    <Label Content="Număr exemplare:"/>
                    <TextBlock Text="{Binding CarteCurenta.NumarExemplare, Mode=OneWay}" Margin="5"/>
                    <Label Content="Gen:"/>
                    <TextBlock Text="{Binding CarteCurenta.Gen, Mode=OneWay}" Margin="5"/>

                    <Label Content="Listă cărți:"/>
                    <ListBox x:Name="lstCarti"
                             Margin="5"
                             Height="130"
                             DisplayMemberPath="Titlu"
                             SelectionChanged="lstCarti_SelectionChanged"/>

                    <Label Content="{Binding ElementName=lstCarti,
                                             Path=Items.Count,
                                             StringFormat='Total cărți: {0}'}"
                           Foreground="DarkBlue"/>

                    <!-- SECTIUNEA AUTORI -->
                    <StackPanel x:Name="panelAutori" Visibility="Collapsed">
                        <TextBlock Text="Gestionare Autori"
                                   FontSize="18" FontWeight="Bold"
                                   Margin="0,15,0,10"/>

                        <Label Content="Nume autor:"/>
                        <TextBox x:Name="txtNumeAutor" Margin="5"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Adaugă" Click="AdaugaAutor_Click"/>
                            <Button Content="Modifică" Click="ModificaAutor_Click"/>
                            <Button Content="Șterge"
                                    Click="StergeAutor_Click"
                                    Background="DarkRed"/>
                        </StackPanel>

                        <Label Content="Listă autori:"/>
                        <ListBox x:Name="lstAutori"
                                 Margin="5"
                                 Height="120"
                                 DisplayMemberPath="Nume"
                                 SelectionChanged="lstAutori_SelectionChanged"/>

                        <Label Content="{Binding ElementName=lstAutori,
                                                 Path=Items.Count,
                                                 StringFormat='Total autori: {0}'}"
                               Foreground="DarkBlue"/>

                        <TextBlock x:Name="txtMesajAutor"
                                   Foreground="DarkGreen"
                                   Margin="5"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- SECTIUNEA PERSOANE -->
                    <StackPanel x:Name="panelPersoane" Visibility="Collapsed">
                        <TextBlock Text="Gestionare Persoane"
                                   FontSize="18" FontWeight="Bold"
                                   Margin="0,15,0,10"/>

                        <Label Content="Nume persoană:"/>
                        <TextBox x:Name="txtNumePersoana" Margin="5"/>

                        <TextBlock x:Name="lblEroarePersoana"
                                   Foreground="Red"
                                   Margin="5,0,5,5"
                                   Visibility="Collapsed"
                                   TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Adaugă" Click="AdaugaPersoana_Click"/>
                            <Button Content="Modifică" Click="ModificaPersoana_Click"/>
                            <Button Content="Șterge"
                                    Click="StergePersoana_Click"
                                    Background="DarkRed"/>
                            <Button Content="Reset"
                                    Click="ResetPersoana_Click"
                                    Background="Gray"/>
                        </StackPanel>

                        <Label Content="Listă persoane:"/>
                        <ListBox x:Name="lstPersoane"
                                 Margin="5"
                                 Height="120"
                                 DisplayMemberPath="Nume"
                                 SelectionChanged="lstPersoane_SelectionChanged"/>

                        <Label Content="{Binding ElementName=lstPersoane,
                                                 Path=Items.Count,
                                                 StringFormat='Total persoane: {0}'}"
                               Foreground="DarkBlue"/>

                        <TextBlock x:Name="txtMesajPersoana"
                                   Foreground="DarkGreen"
                                   Margin="5"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- SECTIUNEA IMPRUMUTURI ACTIVE -->
                    <StackPanel x:Name="panelImprumuturi" Visibility="Collapsed">
                        <TextBlock Text="Împrumuturi active"
                                   FontSize="18" FontWeight="Bold"
                                   Margin="0,15,0,10"/>

                        <DataGrid x:Name="dgImprumuturi"
                                  Margin="5"
                                  Height="160"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Persoană"
                                                   Binding="{Binding Persoana.Nume}"
                                                   Width="*"/>
                                <DataGridTextColumn Header="Carte"
                                                   Binding="{Binding Carte.Titlu}"
                                                   Width="*"/>
                                <DataGridTextColumn Header="Data împrumut"
                                                   Binding="{Binding DataImprumut, StringFormat=dd.MM.yyyy}"
                                                   Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Content="Returnează cartea selectată"
                                Click="ReturneazaSelectata_Click"
                                HorizontalAlignment="Left"
                                Background="DarkGreen"/>

                        <TextBlock x:Name="txtMesajReturnare"
                                   Foreground="DarkGreen"
                                   Margin="5"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                </StackPanel>

                <!-- ===== COLOANA DREAPTA ===== -->
                <StackPanel Grid.Column="1" Margin="5">

                    <TextBlock Text="Tip operație"
                               FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <RadioButton x:Name="radioAdauga"
                                     Content="Carte nouă"
                                     GroupName="Tip"
                                     IsChecked="True"
                                     Margin="5"
                                     Checked="RadioAdauga_Checked"/>
                        <RadioButton x:Name="radioEditeaza"
                                     Content="Editare carte"
                                     GroupName="Tip"
                                     Margin="5"
                                     Checked="RadioEditeaza_Checked"/>
                    </StackPanel>
                    <CheckBox x:Name="chkDisponibila"
                              Content="Disponibilă pentru împrumut"
                              Margin="5"
                              IsChecked="True"/>

                    <!-- SECTIUNEA ADAUGARE -->
                    <StackPanel x:Name="panelAdauga">
                        <TextBlock x:Name="txtTitluFormular"
                                   Text="Adaugă carte"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0,10,0,5"/>

                        <!-- LAB11: Binding TwoWay + ValidatesOnDataErrors -->
                        <Label Content="Titlu carte:"/>
                        <TextBox x:Name="txtTitlu"
                                 Text="{Binding TitluNou,
                                                Mode=TwoWay,
                                                UpdateSourceTrigger=PropertyChanged,
                                                ValidatesOnDataErrors=True}"/>
                        <TextBlock Text="{Binding ElementName=txtTitlu,
                                                   Path=(Validation.Errors)/ErrorContent}"
                                   Foreground="Red" FontSize="11" Margin="5,0,5,5"/>

                        <Label Content="Autor:"/>
                        <TextBox x:Name="txtAutor"
                                 Text="{Binding AutorNou,
                                                Mode=TwoWay,
                                                UpdateSourceTrigger=PropertyChanged,
                                                ValidatesOnDataErrors=True}"/>
                        <TextBlock Text="{Binding ElementName=txtAutor,
                                                   Path=(Validation.Errors)/ErrorContent}"
                                   Foreground="Red" FontSize="11" Margin="5,0,5,5"/>

                        <Label Content="Număr exemplare:"/>
                        <TextBox x:Name="txtNrExemplare"
                                 Text="{Binding NrExemplareNou,
                                                Mode=TwoWay,
                                                UpdateSourceTrigger=PropertyChanged,
                                                ValidatesOnDataErrors=True}"/>
                        <TextBlock Text="{Binding ElementName=txtNrExemplare,
                                                   Path=(Validation.Errors)/ErrorContent}"
                                   Foreground="Red" FontSize="11" Margin="5,0,5,5"/>

                        <Label Content="Data achiziției:"/>
                        <DatePicker x:Name="dtpDataAchizitie"
                                    Margin="5"
                                    SelectedDateFormat="Short"/>

                        <Label Content="Gen carte (selectați din listă):"/>
                        <ListBox x:Name="lstGenCarte"
                                 Margin="5"
                                 Height="110"
                                 SelectionMode="Single"
                                 SelectionChanged="lstGenCarte_SelectionChanged"/>

                        <!-- LAB11: Buton activ doar cand EsteValid == true -->
                        <Button Content="Adaugă carte"
                                x:Name="btnAdauga"
                                Click="AdaugaCarte_Click"
                                IsEnabled="{Binding EsteValid}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- SECTIUNEA MODIFICARE -->
                    <StackPanel x:Name="panelModifica" Visibility="Collapsed">
                        <TextBlock Text="Modifică carte"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0,10,0,5"/>

                        <Label Content="Selectați cartea de modificat:"/>
                        <ComboBox x:Name="cmbCarti"
                                  Margin="5"
                                  Height="30"
                                  DisplayMemberPath="Titlu"
                                  SelectionChanged="cmbCarti_SelectionChanged"/>

                        <Label Content="Titlu carte:"/>
                        <TextBox x:Name="txtTitluModifica"/>

                        <Label Content="Autor:"/>
                        <TextBox x:Name="txtAutorModifica"/>

                        <Label Content="Număr exemplare:"/>
                        <TextBox x:Name="txtNrExemplareModifica"/>

                        <Label Content="Data actualizării:"/>
                        <DatePicker x:Name="dtpDataActualizare"
                                    Margin="5"
                                    SelectedDateFormat="Short"
                                    IsEnabled="False"/>

                        <Label Content="Gen carte:"/>
                        <ListBox x:Name="lstGenCarteModifica"
                                 Margin="5"
                                 Height="110"
                                 SelectionMode="Single"
                                 SelectionChanged="lstGenCarteModifica_SelectionChanged"/>

                        <Button Content="Actualizează"
                                Click="ActualizeazaCarte_Click"
                                HorizontalAlignment="Left"/>

                        <TextBlock x:Name="txtMesajModifica"
                                   Foreground="DarkGreen"
                                   Margin="5"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- SECTIUNEA IMPRUMUT -->
                    <StackPanel x:Name="panelImprumuta" Visibility="Collapsed">
                        <TextBlock Text="Împrumută carte"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0,10,0,5"/>

                        <Label Content="Selectați persoana:"/>
                        <ComboBox x:Name="cmbPersoaneImprumut"
                                  Margin="5"
                                  Height="30"
                                  DisplayMemberPath="Nume"
                                  SelectionChanged="cmbPersoaneImprumut_SelectionChanged"/>

                        <TextBlock x:Name="txtAvertismentLimita"
                                   Foreground="Red"
                                   FontWeight="Bold"
                                   Margin="5"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>

                        <TextBlock x:Name="txtInfoCartiPersoana"
                                   Foreground="DarkBlue"
                                   Margin="5"
                                   TextWrapping="Wrap"/>

                        <Label Content="Selectați cartea:"/>
                        <ComboBox x:Name="cmbCartiImprumut"
                                  Margin="5"
                                  Height="30"
                                  DisplayMemberPath="Titlu"
                                  SelectionChanged="cmbCartiImprumut_SelectionChanged"/>

                        <TextBlock x:Name="txtInfoDisponibilitateCarte"
                                   Margin="5"
                                   TextWrapping="Wrap"/>

                        <Label Content="Data împrumutului:"/>
                        <DatePicker x:Name="dtpDataImprumut"
                                    Margin="5"
                                    SelectedDateFormat="Short"/>

                        <Button x:Name="btnImprumuta"
                                Content="Confirmă împrumutul"
                                Click="ConfirmaImprumut_Click"
                                Background="DarkGreen"
                                HorizontalAlignment="Left"/>

                        <TextBlock x:Name="txtMesajImprumut"
                                   Foreground="DarkGreen"
                                   Margin="5"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- SECTIUNEA RETURNARE -->
                    <StackPanel x:Name="panelReturneaza" Visibility="Collapsed">
                        <TextBlock Text="Returnează carte"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0,10,0,5"/>

                        <Label Content="Selectați persoana:"/>
                        <ComboBox x:Name="cmbPersoaneReturnare"
                                  Margin="5"
                                  Height="30"
                                  DisplayMemberPath="Nume"
                                  SelectionChanged="cmbPersoaneReturnare_SelectionChanged"/>

                        <Label Content="Selectați împrumutul de returnat:"/>
                        <ComboBox x:Name="cmbImprumuturiReturnare"
                                  Margin="5"
                                  Height="30"
                                  DisplayMemberPath="Carte.Titlu"/>

                        <Button Content="Confirmă returnarea"
                                Click="ConfirmaReturnare_Click"
                                Background="DarkGreen"
                                HorizontalAlignment="Left"/>

                        <TextBlock x:Name="txtMesajReturnare2"
                                   Foreground="DarkGreen"
                                   Margin="5"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- CAUTARE -->
                    <TextBlock Text="Căutare carte"
                               FontSize="16" FontWeight="Bold"
                               Margin="0,15,0,5"/>
                    <Label Content="Caută după titlu:"/>
                    <TextBox x:Name="txtCautare"/>
                    <Button Content="Caută"
                            Click="Cauta_Click"
                            HorizontalAlignment="Left"/>
                    <TextBlock x:Name="txtRezultatCautare"
                               Margin="5"
                               Foreground="DarkGreen"
                               TextWrapping="Wrap"/>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>